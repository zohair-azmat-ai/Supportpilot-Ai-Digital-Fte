# ─────────────────────────────────────────────────────────────────────────────
# SupportPilot AI — Frontend Environment Variables
# Copy this file to .env.local for local development.
# On Vercel, set these in: Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (must include /api/v1)
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
#
# Production (Hugging Face Space) — paste this value into Vercel dashboard:
# NEXT_PUBLIC_API_URL=https://zohairazmat-supportpilot-ai-fte.hf.space/api/v1
