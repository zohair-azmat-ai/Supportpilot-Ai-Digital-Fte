# ─────────────────────────────────────────────────────────────────────────────
# SupportPilot AI — Backend Environment Variables
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Database (PostgreSQL async connection string)
#
# Use postgresql+asyncpg:// scheme (required by SQLAlchemy asyncio).
# Plain postgresql:// and postgres:// are auto-corrected at startup.
#
# Libpq/psycopg2-only query parameters are automatically stripped so they do
# not cause "unexpected keyword argument" errors in asyncpg.  Stripped params:
#   channel_binding, gssencmode, krbsrvname, sslcompression,
#   target_session_attrs, load_balance_hosts, hostaddr, service,
#   replication, connect_timeout
#
# sslmode is also stripped but translated:
#   sslmode=require / verify-ca / verify-full  →  connect_args ssl=True
#   sslmode=disable / allow / prefer           →  no SSL (stripped silently)
#
# Examples:
#   Local (no SSL):  postgresql+asyncpg://postgres:password@localhost:5432/supportpilot
#   Neon / cloud:    postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/supportpilot?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/supportpilot

# JWT Security
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Runtime environment
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────────
# Event Bus / Kafka
# ─────────────────────────────────────────────────────────────────────────────
# USE_KAFKA=false  → InMemoryEventBus (default, no Kafka needed for local dev)
# USE_KAFKA=true   → KafkaEventBus (production, requires running Kafka cluster)
USE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=supportpilot

# ─────────────────────────────────────────────────────────────────────────────
# Channel Integrations (optional — activate by filling in credentials)
# ─────────────────────────────────────────────────────────────────────────────

# Gmail (email channel)
# See backend/app/channels/email.py for activation checklist
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_SENDER_ADDRESS=support@yourdomain.com

# WhatsApp / Twilio
# See backend/app/channels/whatsapp.py for activation checklist
# Backend startup stays safe if these are missing; the webhook returns 503 until
# TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, and TWILIO_WHATSAPP_FROM are all set.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_STATUS_CALLBACK=https://your-backend.example.com/api/v1/channels/whatsapp/status
